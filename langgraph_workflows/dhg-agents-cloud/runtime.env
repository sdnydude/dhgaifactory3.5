# Runtime configuration (non-secret) — committed to git
# API keys and secrets are set in LangSmith deployment Secrets UI

# Auto-approve pipeline without human review (set true to run end-to-end)
SKIP_HUMAN_REVIEW=false

# OpenTelemetry span export endpoint (Cloudflare-tunneled Tempo OTLP/HTTP receiver)
OTEL_EXPORTER_OTLP_ENDPOINT=https://otel.digitalharmonyai.com
